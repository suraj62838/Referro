# ---------- Django ----------
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------- Database ----------
DATABASE_URL=postgres://user:password@localhost:5432/referro

# ---------- Redis / Celery ----------
REDIS_URL=redis://localhost:6379/0

# ---------- JWT ----------
JWT_SIGNING_KEY=

# ---------- Google OAuth (Gmail send/receive) ----------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/email-accounts/oauth/callback/

# ---------- AI / LLM ----------
GROQ_API_KEY=

# ---------- Field-level encryption for OAuth tokens (Phase 5) ----------
# Fernet key. Leave blank in dev to auto-derive from SECRET_KEY.
# In production, generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

